# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://marktech:marktech_dev@localhost:5432/marktech_ads

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Server ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_in_production_32_chars_min

# ─── Meta Marketing API ─────────────────────────────────────
# Apply at: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_LONG_LIVED_TOKEN=
META_BUSINESS_MANAGER_ID=

# ─── Google Ads API ─────────────────────────────────────────
# Apply at: https://developers.google.com/google-ads/api/docs/get-started/introduction
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_MANAGER_ACCOUNT_ID=

# ─── Anthropic / Claude API ─────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Auth (Clerk) ───────────────────────────────────────────
# https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Frontend ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=

# ─── Stripe Billing ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Encryption ─────────────────────────────────────────────
# 32-byte hex key for AES-256 token encryption
ENCRYPTION_KEY=
